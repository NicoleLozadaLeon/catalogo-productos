# .env.example — variables de entorno para la app
# COPIA este archivo a .env y rellena los valores reales.
# El archivo .env NUNCA debe subirse a Git (está en .gitignore).

# ── Servidor ──────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Base de datos PostgreSQL ──────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=catalogo
DB_USER=postgres
DB_PASSWORD=CAMBIA_ESTO_NUNCA_EN_GIT

# ── AWS (solo necesario en Fase 4 con USE_S3=true) ────────────────
USE_S3=false
AWS_REGION=us-east-1
S3_BUCKET=nombre-de-tu-bucket

# NOTA: Las credenciales de AWS NUNCA van en .env.
# En local Docker: heredarás las del ~/.aws/credentials.
# En EC2: las provee el Instance Profile automáticamente.
